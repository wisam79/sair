# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/uniride
TEST_DATABASE_URL=postgresql://user:pass@localhost:5432/uniride_test

# API Server
PORT=3000
SESSION_SECRET=your_jwt_secret_here_min_32_chars

# WhatsApp OTP (Meta Graph API)
WHATSAPP_TOKEN=your_meta_graph_api_token
WHATSAPP_PHONE_ID=your_phone_number_id

# Supabase (Mobile App)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
EXPO_PUBLIC_API_URL=http://localhost:3000
