{
  "expo": {
    "name": "UniRide",
    "slug": "uniride",
    "scheme": "uniride",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D2D2D"
    },
    "assetBundlePatterns": ["**/*"],
    "fonts": [
      "./node_modules/@expo-google-fonts/ibm-plex-sans-arabic/IBMPlexSansArabic_400Regular.ttf",
      "./node_modules/@expo-google-fonts/ibm-plex-sans-arabic/IBMPlexSansArabic_500Medium.ttf",
      "./node_modules/@expo-google-fonts/ibm-plex-sans-arabic/IBMPlexSansArabic_700Bold.ttf"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#C2703E"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}

