{
  "expo": {
    "name": "سير",
    "slug": "sair",
    "scheme": "sair",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#161616"
    },
    "assetBundlePatterns": ["**/*"],
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": ["location", "remote-notification"],
        "NSLocationAlwaysAndWhenInUseUsageDescription": "نحتاج للوصول لموقعك في الخلفية لمطابقة مسار الرحلة وتتبع الحافلة.",
        "NSLocationWhenInUseUsageDescription": "نحتاج للوصول لموقعك لتتبع الرحلة وعرضها على الخريطة."
      }
    },
    "android": {
      "package": "com.wisam99sr.sair",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#161616"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "WAKE_LOCK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "56de5863-9707-4eb0-a22f-23e58c5e5a2f"
      }
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      "@maplibre/maplibre-react-native",
      "@react-native-google-signin/google-signin",
      [
        "onesignal-expo-plugin",
        {
          "mode": "development"
        }
      ],
      "expo-video",
      "expo-audio"
    ],
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#16A34A"
    },
    "owner": "wisam99sr"
  }
}
