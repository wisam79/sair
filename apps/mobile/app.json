{
  "expo": {
    "name": "سير",
    "slug": "sair",
    "scheme": "sair",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D2D2D"
    },
    "assetBundlePatterns": ["**/*"],
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.wisam99sr.sair",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#C2703E"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "28fa1803-2b1d-4c78-b4af-9b0fd8cce561"
      }
    },
    "plugins": ["expo-font", "expo-secure-store", "expo-web-browser"],
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#C2703E"
    },
    "owner": "wisam99sr"
  }
}
