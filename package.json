{
  "name": "sair-v2",
  "version": "2.0.0",
  "private": true,
  "description": "Sair - Clean Smart Transit Platform",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "test": "vitest run",
    "test:mobile": "vitest run --config vitest.mobile.config.ts",
    "test:integration": "cross-env RUN_INTEGRATION_TESTS=true vitest run tests/integration/",
    "test:concurrency": "cross-env RUN_INTEGRATION_TESTS=true vitest run tests/integration/concurrency.integration.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:all": "vitest run && vitest run --config vitest.mobile.config.ts",
    "test:e2e": "playwright test",
    "typecheck": "pnpm -r typecheck",
    "mobile:doctor": "pnpm --filter mobile-app exec expo install --check",
    "mobile:export:android": "pnpm --filter mobile-app exec expo export --platform android",
    "format": "pnpm format:write",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "lint": "eslint \"**/*.{ts,tsx}\" --max-warnings=0",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@expo/ngrok": "^4.1.3",
    "@playwright/test": "^1.59.1",
    "@react-native/debugger-frontend": "^0.85.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^1.6.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "jose": "^6.2.3",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.3",
    "prettier": "^3.2.5",
    "semantic-release": "^25.0.3",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "react-native-maps": "1.20.1",
      "@types/react": "19.1.10"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{js,jsx,json,md}": [
      "prettier --write"
    ]
  }
}
